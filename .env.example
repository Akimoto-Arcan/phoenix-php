# PhoenixPHP Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME="PhoenixPHP Application"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

# Primary Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=phoenix_app
DB_USERNAME=root
DB_PASSWORD=

# Users Database (authentication)
USERS_DATABASE=phoenix_users

# Mail Configuration
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_EMAIL=noreply@example.com
MAIL_FROM_NAME="Phoenix System"

# Cache
CACHE_DRIVER=file
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Security
SESSION_LIFETIME=720
CSRF_TOKEN_EXPIRY=3600
RATE_LIMIT_LOGIN=5
RATE_LIMIT_API=100
